// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  LANDLORD
}

model User {
  id               String            @id @default(cuid())
  auth0Id          String?           @unique
  email            String            @unique
  name             String?
  avatarUrl        String?
  role             Role              @default(STUDENT)
  isVerified       Boolean           @default(false)
  bio              String?
  program          String?
  gradYear         Int?
  karma            Int               @default(0)
  responseRate     Float?
  createdAt        DateTime          @default(now())
  listings         Listing[]
  reviews          Review[]
  posts            Post[]
  comments         Comment[]
  marketItems      MarketplaceItem[]
  savedListings    SavedListing[]
}

model Listing {
  id                String   @id @default(cuid())
  title             String
  rent              Float
  bedrooms          Int
  bathrooms         Int      @default(1)
  address           String
  description       String
  imageUrl          String?
  amenities         String[] 
  utilitiesIncluded Boolean  @default(false)
  leaseLength       Int      @default(12)
  deposit           Float?
  availableFrom     DateTime?
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  reviews           Review[]
  savedBy           SavedListing[]
  createdAt         DateTime @default(now())
}

model Review {
  id                String   @id @default(cuid())
  landlordName      String
  landlordAddress   String
  rating            Int
  depositReturned   Boolean
  maintenanceRating Int
  reviewText        String
  leaseProofUrl     String?
  solanaHash        String?
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  listingId         String?
  listing           Listing? @relation(fields: [listingId], references: [id])
  comments          ReviewComment[]
  createdAt         DateTime @default(now())
}

model ReviewComment {
  id        String   @id @default(cuid())
  content   String
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

enum PostCategory {
  ROOMMATE
  HOUSING
  GENERAL
  SELLING
}

model Post {
  id        String       @id @default(cuid())
  title     String
  content   String
  category  PostCategory @default(GENERAL)
  upvotes   Int          @default(0)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  comments  Comment[]
  createdAt DateTime     @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model MarketplaceItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String
  imageUrl    String?
  contactInfo String
  isSold      Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())
}
